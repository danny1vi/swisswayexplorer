---
type Card = {
  title: string;
  summary: string;
  href: string;
  imageUrl?: string;
};

type Props = {
  title?: string;
  items: Card[];
};

const { title = "Featured Destinations", items } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="heading-row">
      <h2>{title}</h2>
    </div>
    <div class="grid">
      {items.map((item) => (
        <article class="card item">
          {item.imageUrl ? (
            <div class="card-image">
              <img src={item.imageUrl} alt={item.title} loading="lazy" />
            </div>
          ) : (
            <div class="card-image card-image-placeholder"></div>
          )}
          <div class="card-body">
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <a href={item.href}>Read overview →</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .heading-row h2 {
    margin: 0 0 1rem;
    font-size: 1.45rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .item {
    padding: 0;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .item:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(12, 39, 58, 0.08);
  }

  .card-image {
    width: 100%;
    height: 160px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-image-placeholder {
    background: linear-gradient(135deg, var(--border) 0%, #e8f0f8 100%);
  }

  .card-body {
    padding: 1.2rem;
  }

  .item h3 {
    margin: 0;
    font-size: 1.1rem;
  }

  .item p {
    margin: 0.55rem 0 0;
    color: var(--muted);
    min-height: 3.5em;
  }

  .item a {
    display: inline-block;
    margin-top: 0.8rem;
    text-decoration: none;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.92rem;
  }

  @media (max-width: 960px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
