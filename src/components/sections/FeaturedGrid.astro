---
import { truncateText } from "../../lib/truncate";

type Card = {
  eyebrow?: string;
  title: string;
  summary: string;
  href: string;
  imageUrl?: string;
};

type Props = {
  title?: string;
  intro?: string;
  items: Card[];
};

const { title = "Choose the base with the highest planning leverage.", intro, items } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="heading-row">
      <p class="section-label">Destination Briefs</p>
      <h2 class="section-title">{title}</h2>
      {intro && <p class="section-copy">{intro}</p>}
    </div>
    <div class="grid">
      {items.map((item) => (
        <article class="card item">
          {item.imageUrl ? (
            <div class="card-image">
              <img src={item.imageUrl} alt={item.title} loading="lazy" />
            </div>
          ) : (
            <div class="card-image card-image-placeholder" aria-hidden="true">
              <span class="placeholder-label">{item.title}</span>
            </div>
          )}
            <div class="card-body">
              {item.eyebrow && <p class="card-eyebrow">{item.eyebrow}</p>}
              <h3>{item.title}</h3>
            <p>{truncateText(item.summary, 100)}</p>
            <a href={item.href}>Read brief</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .heading-row {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    max-width: 62rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .item {
    padding: 0;
    overflow: hidden;
  }

  .item:hover,
  .item:focus-within {
    transform: translateY(-4px);
    box-shadow: 0 28px 64px rgba(22, 37, 31, 0.12);
  }

  .card-image {
    width: 100%;
    height: 250px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-image-placeholder {
    background:
      radial-gradient(circle at top right, rgba(201, 168, 76, 0.18), transparent 45%),
      linear-gradient(135deg, #efe8dc 0%, #f7f2ea 100%);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
  }

  .placeholder-label {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--primary);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .card-body {
    display: grid;
    gap: 0.8rem;
    padding: 1.35rem;
  }

  .card-eyebrow {
    margin: 0;
    color: var(--primary);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 700;
  }

  .item h3 {
    margin: 0;
    font-size: 1.45rem;
    line-height: 1.05;
  }

  .item p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .item a {
    display: inline-block;
    margin-top: 0.1rem;
    text-decoration: none;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.92rem;
  }

  @media (max-width: 960px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
