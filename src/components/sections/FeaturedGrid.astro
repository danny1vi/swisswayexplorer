---
import { truncateText } from "../../lib/truncate";

type Card = {
  eyebrow?: string;
  title: string;
  summary: string;
  href: string;
  imageUrl?: string;
  imageAlt?: string;
};

type Props = {
  title?: string;
  intro?: string;
  items: Card[];
};

const { title = "Choose the base with the highest planning leverage.", intro, items } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="heading-row">
      <p class="section-label">Destination Briefs</p>
      <h2 class="section-title">{title}</h2>
      {intro && <p class="section-copy">{intro}</p>}
    </div>
    <div class="grid">
      {items.map((item) => (
        <a class="card item" href={item.href}>
          {item.imageUrl ? (
            <div class="card-image">
              <img src={item.imageUrl} alt={item.imageAlt || item.title} loading="lazy" />
            </div>
          ) : (
            <div class="card-image card-image-placeholder" aria-hidden="true">
              <span class="placeholder-label">{item.title}</span>
            </div>
          )}
          <div class="card-body">
            {item.eyebrow && <p class="card-eyebrow">{item.eyebrow}</p>}
            <h3>{item.title}</h3>
            <p>{truncateText(item.summary, 100)}</p>
            <span class="card-link">Read brief</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .heading-row {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    max-width: 62rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .item {
    display: grid;
    padding: 0;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border-radius: calc(var(--radius) + 12px);
  }

  .item:hover,
  .item:focus-within {
    transform: translateY(-4px);
    box-shadow: 0 32px 72px rgba(22, 37, 31, 0.14);
  }

  .card-image {
    width: 100%;
    height: 270px;
    overflow: hidden;
    position: relative;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 240ms ease;
  }

  .item:hover .card-image img,
  .item:focus-visible .card-image img {
    transform: scale(1.04);
  }

  .card-image::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 34%;
    background: linear-gradient(180deg, rgba(13, 24, 21, 0) 0%, rgba(13, 24, 21, 0.28) 100%);
    pointer-events: none;
  }

  .card-image-placeholder {
    background:
      radial-gradient(circle at top right, rgba(201, 168, 76, 0.18), transparent 45%),
      linear-gradient(135deg, #efe8dc 0%, #f7f2ea 100%);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
  }

  .placeholder-label {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--primary);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .card-body {
    display: grid;
    gap: 0.85rem;
    padding: 1.15rem 1.2rem 1.25rem;
  }

  .card-eyebrow {
    margin: 0;
    color: var(--primary);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    background: rgba(26, 60, 52, 0.06);
    border: 1px solid rgba(26, 60, 52, 0.08);
    border-radius: 999px;
    width: fit-content;
    padding: 0.36rem 0.58rem;
  }

  .item h3 {
    margin: 0;
    font-size: 1.52rem;
    line-height: 1.08;
    max-width: 16ch;
  }

  .item p {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
    max-width: 34ch;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.1rem;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.92rem;
  }

  .card-link::after {
    content: "->";
    transition: transform 200ms ease;
  }

  .item:hover .card-link::after,
  .item:focus-visible .card-link::after {
    transform: translateX(2px);
  }

  @media (max-width: 960px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
