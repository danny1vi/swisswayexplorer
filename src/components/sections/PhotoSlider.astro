---
type SliderItem = {
  href: string;
  imageUrl: string;
  imageAlt?: string;
};

type Props = {
  items: SliderItem[];
};

const { items } = Astro.props;
const sliderId = "homepage-photo-slider";
---

{items.length > 0 && (
  <section class="section photo-slider-section" aria-label="Featured travel photos">
    <div class="container">
      <div class="photo-slider-shell">
        <button class="slider-arrow slider-arrow-prev" type="button" aria-label="Previous photos" data-slider-prev={sliderId}>
          <span aria-hidden="true">←</span>
        </button>
        <div class="photo-slider-track" id={sliderId} data-photo-slider>
          {items.map((item) => (
            <a class="photo-slide" href={item.href}>
              <img src={item.imageUrl} alt={item.imageAlt || ""} loading="lazy" />
            </a>
          ))}
        </div>
        <button class="slider-arrow slider-arrow-next" type="button" aria-label="Next photos" data-slider-next={sliderId}>
          <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>
  </section>
)}

<script is:inline define:vars={{ sliderId }}>
  (function () {
    const track = document.getElementById(sliderId);
    const prevButton = document.querySelector(`[data-slider-prev="${sliderId}"]`);
    const nextButton = document.querySelector(`[data-slider-next="${sliderId}"]`);

    if (!(track instanceof HTMLElement)) return;

    const slides = Array.from(track.querySelectorAll(".photo-slide"));
    if (slides.length === 0) return;

    // Clone first and last N slides for seamless infinite loop
    const clonesCount = Math.min(2, slides.length);
    const clonesStart = slides.slice(0, clonesCount).map(s => s.cloneNode(true));
    const clonesEnd = slides.slice(-clonesCount).map(s => s.cloneNode(true));

    clonesEnd.forEach(c => track.appendChild(c));
    clonesStart.slice().reverse().forEach(c => track.prependChild(c));

    // After prepending clones, real slides are at index [clonesCount .. clonesCount + slides.length - 1]
    const realStartIndex = clonesCount;
    const realEndIndex = clonesCount + slides.length - 1;

    // Jump positions (in pixels)
    const getSlideLeft = (index) => {
      const slide = track.querySelectorAll(".photo-slide")[index];
      if (!slide) return 0;
      return slide.offsetLeft;
    };

    const totalRealSlides = slides.length;

    // Get gap from CSS
    const getGap = () => {
      const style = window.getComputedStyle(track);
      return Number.parseFloat(style.columnGap || style.gap || "0");
    };

    const slideWidth = () => {
      const firstSlide = track.querySelector(".photo-slide");
      if (!(firstSlide instanceof HTMLElement)) return track.clientWidth * 0.82;
      return firstSlide.offsetWidth + getGap();
    };

    let isJumping = false;
    let autoAdvance;

    const move = (direction) => {
      const allSlides = track.querySelectorAll(".photo-slide");
      const currentIndex = Math.round(track.scrollLeft / (slideWidth() - getGap()));
      const targetIndex = currentIndex + direction;
      const targetLeft = getSlideLeft(targetIndex);
      track.scrollTo({ left: targetLeft, behavior: "smooth" });
    };

    const jumpToReal = (realIndex) => {
      isJumping = true;
      track.scrollTo({ left: getSlideLeft(realIndex), behavior: "instant" });
      setTimeout(() => { isJumping = false; }, 60);
    };

    const handleScroll = () => {
      if (isJumping) return;
      const allSlides = track.querySelectorAll(".photo-slide");
      const total = allSlides.length;

      // If we scrolled into the cloned start region (before real first slides), jump to real end
      if (total > clonesCount * 2) {
        const clonedStartThreshold = getSlideLeft(clonesCount - 1);
        if (track.scrollLeft < clonedStartThreshold - slideWidth() * 0.5) {
          jumpToReal(realEndIndex);
          return;
        }

        // If we scrolled into the cloned end region (after real last slides), jump to real start
        const clonedEndThreshold = getSlideLeft(total - clonesCount);
        if (track.scrollLeft > clonedEndThreshold - slideWidth() * 0.5) {
          jumpToReal(realStartIndex);
          return;
        }
      }
    };

    prevButton?.addEventListener("click", () => move(-1));
    nextButton?.addEventListener("click", () => move(1));

    const stopAuto = () => clearInterval(autoAdvance);
    const startAuto = () => {
      stopAuto();
      autoAdvance = setInterval(() => move(1), 4200);
    };

    track.addEventListener("scroll", handleScroll, { passive: true });
    track.addEventListener("mouseenter", stopAuto);
    track.addEventListener("mouseleave", startAuto);
    track.addEventListener("focusin", stopAuto);
    track.addEventListener("focusout", startAuto);

    // Initialize scroll position to real first slide (skip clones)
    track.scrollTo({ left: getSlideLeft(realStartIndex), behavior: "instant" });

    startAuto();
  })();
</script>

<style>
  .photo-slider-section {
    padding-top: 0.35rem;
  }

  .photo-slider-shell {
    position: relative;
    display: grid;
    align-items: center;
  }

  .photo-slider-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(260px, 1fr);
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding: 0 3rem;
    scroll-behavior: smooth;
  }

  .photo-slider-track::-webkit-scrollbar {
    display: none;
  }

  .photo-slide {
    position: relative;
    display: block;
    aspect-ratio: 4 / 5;
    border-radius: calc(var(--radius) + 12px);
    overflow: hidden;
    scroll-snap-align: center;
    box-shadow: var(--shadow-soft);
    background: linear-gradient(135deg, #f0ece2 0%, #ded5c6 100%);
    border: 1px solid rgba(26, 60, 52, 0.1);
  }

  .photo-slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(12, 26, 23, 0.02) 0%, rgba(12, 26, 23, 0.12) 100%);
    pointer-events: none;
  }

  .photo-slide:hover,
  .photo-slide:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 32px 72px rgba(22, 37, 31, 0.16);
  }

  .photo-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 260ms ease;
  }

  .photo-slide:hover img,
  .photo-slide:focus-visible img {
    transform: scale(1.04);
  }

  .slider-arrow {
    position: absolute;
    top: 50%;
    z-index: 2;
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(26, 60, 52, 0.14);
    background: rgba(255, 252, 245, 0.92);
    color: var(--primary);
    box-shadow: 0 18px 40px rgba(22, 37, 31, 0.14);
    cursor: pointer;
    transform: translateY(-50%);
    backdrop-filter: blur(10px);
  }

  .slider-arrow:hover,
  .slider-arrow:focus-visible {
    background: rgba(255, 252, 245, 1);
  }

  .slider-arrow-prev {
    left: 0;
  }

  .slider-arrow-next {
    right: 0;
  }

  @media (max-width: 960px) {
    .photo-slider-track {
      grid-auto-columns: minmax(220px, 82vw);
      padding: 0 0.5rem;
    }

    .slider-arrow {
      display: none;
    }
  }
</style>
