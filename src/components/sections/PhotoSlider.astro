---
type SliderItem = {
  href: string;
  imageUrl: string;
  imageAlt?: string;
};

type Props = {
  items: SliderItem[];
};

const { items } = Astro.props;
const sliderId = "homepage-photo-slider";
---

{items.length > 0 && (
  <section class="section photo-slider-section" aria-label="Featured travel photos">
    <div class="container">
      <div class="photo-slider-shell">
        <button
          class="slider-arrow slider-arrow-prev"
          type="button"
          aria-label="Previous photos"
          id={`${sliderId}-prev`}
        >
          <span aria-hidden="true">&#8592;</span>
        </button>
        <div
          class="photo-slider-track"
          id={sliderId}
          data-photo-slider
        >
          {items.map((item) => (
            <a class="photo-slide" href={item.href}>
              <img src={item.imageUrl} alt={item.imageAlt || ""} loading="lazy" />
            </a>
          ))}
        </div>
        <button
          class="slider-arrow slider-arrow-next"
          type="button"
          aria-label="Next photos"
          id={`${sliderId}-next`}
        >
          <span aria-hidden="true">&#8594;</span>
        </button>
      </div>
    </div>
  </section>
)}

<script is:inline define:vars={{ sliderId }}>
  (function () {
    var track = document.getElementById(sliderId);
    if (!track) return;

    var prevBtn = document.getElementById(sliderId + "-prev");
    var nextBtn = document.getElementById(sliderId + "-next");
    if (!prevBtn || !nextBtn) return;

    var autoTimer;

    // Collect original slides
    var originalSlides = Array.prototype.slice.call(track.querySelectorAll(".photo-slide"));
    var REAL_COUNT = originalSlides.length;
    if (REAL_COUNT < 2) return;

    // Clone 1 slide from each end for infinite loop illusion
    var CLONE_COUNT = 1;
    var lastClone = originalSlides[REAL_COUNT - 1].cloneNode(true);
    var firstClone = originalSlides[0].cloneNode(true);

    // Prepend lastClone (before all real slides)
    track.insertBefore(lastClone, track.firstChild);
    // Append firstClone (after all real slides)
    track.appendChild(firstClone);

    // Re-query all slides including clones: order is [lastClone, R0...R4, firstClone]
    var allSlides = track.querySelectorAll(".photo-slide");
    var TOTAL = allSlides.length; // REAL_COUNT + 2

    // realStart=1, realEnd=TOTAL-2 (index of last real slide)
    var REAL_START = CLONE_COUNT;           // = 1
    var REAL_END = TOTAL - CLONE_COUNT - 1; // = TOTAL - 2

    // Track current index directly — not derived from scrollLeft
    var currentIdx = REAL_START; // start on first real slide

    // Get exact pixel offset of a slide index
    function getOffset(idx) {
      return allSlides[idx].offsetLeft - track.offsetLeft;
    }

    // Instant jump to a slide index (no animation)
    function jumpToIdx(idx) {
      idx = Math.max(0, Math.min(TOTAL - 1, idx));
      currentIdx = idx;
      track.scrollLeft = getOffset(idx);
    }

    // Initialize: scroll to first real slide (index 1)
    jumpToIdx(REAL_START);

    // --- Navigation (instant scroll, no animation to avoid scroll-behavior conflicts) ---

    function goToNext() {
      var nextIdx = currentIdx + 1;
      if (nextIdx > REAL_END) {
        // Past last real — instant jump to first real slide (seamless loop)
        jumpToIdx(REAL_START);
      } else {
        jumpToIdx(nextIdx);
      }
    }

    function goToPrev() {
      var prevIdx = currentIdx - 1;
      if (prevIdx < REAL_START) {
        // Past first real — instant jump to last real slide (seamless loop)
        jumpToIdx(REAL_END);
      } else {
        jumpToIdx(prevIdx);
      }
    }

    function startAuto() {
      stopAuto();
      autoTimer = setInterval(goToNext, 4200);
    }

    function stopAuto() {
      clearInterval(autoTimer);
    }

    // Pause on hover
    track.addEventListener("mouseenter", stopAuto);
    track.addEventListener("mouseleave", startAuto);

    // Button clicks
    prevBtn.addEventListener("click", function () {
      stopAuto();
      goToPrev();
      startAuto();
    });

    nextBtn.addEventListener("click", function () {
      stopAuto();
      goToNext();
      startAuto();
    });

    startAuto();
  })();
</script>

<style>
  .photo-slider-section {
    padding-top: 0.35rem;
  }

  .photo-slider-shell {
    position: relative;
    display: grid;
    align-items: center;
  }

  .photo-slider-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(260px, 1fr);
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding: 0 3rem;
    scroll-behavior: auto;
    /* Explicitly override global html{scroll-behavior:smooth} */
  }

  .photo-slider-track::-webkit-scrollbar {
    display: none;
  }

  .photo-slide {
    position: relative;
    display: block;
    aspect-ratio: 4 / 5;
    border-radius: calc(var(--radius) + 12px);
    overflow: hidden;
    scroll-snap-align: center;
    box-shadow: var(--shadow-soft);
    background: linear-gradient(135deg, #f0ece2 0%, #ded5c6 100%);
    border: 1px solid rgba(26, 60, 52, 0.1);
  }

  .photo-slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(12, 26, 23, 0.02) 0%, rgba(12, 26, 23, 0.12) 100%);
    pointer-events: none;
  }

  .photo-slide:hover,
  .photo-slide:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 32px 72px rgba(22, 37, 31, 0.16);
  }

  .photo-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 260ms ease;
  }

  .photo-slide:hover img,
  .photo-slide:focus-visible img {
    transform: scale(1.04);
  }

  .slider-arrow {
    position: absolute;
    top: 50%;
    z-index: 2;
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(26, 60, 52, 0.14);
    background: rgba(255, 252, 245, 0.92);
    color: var(--primary);
    box-shadow: 0 18px 40px rgba(22, 37, 31, 0.14);
    cursor: pointer;
    transform: translateY(-50%);
    backdrop-filter: blur(10px);
  }

  .slider-arrow:hover,
  .slider-arrow:focus-visible {
    background: rgba(255, 252, 245, 1);
  }

  .slider-arrow-prev {
    left: 0;
  }

  .slider-arrow-next {
    right: 0;
  }

  @media (max-width: 960px) {
    .photo-slider-track {
      grid-auto-columns: minmax(220px, 82vw);
      padding: 0 0.5rem;
    }

    .slider-arrow {
      display: none;
    }
  }
</style>
