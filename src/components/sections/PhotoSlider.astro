---
type SliderItem = {
  href: string;
  imageUrl: string;
  imageAlt?: string;
};

type Props = {
  items: SliderItem[];
};

const { items } = Astro.props;
const sliderId = "homepage-photo-slider";
---

{items.length > 0 && (
  <section class="section photo-slider-section" aria-label="Featured travel photos">
    <div class="container">
      <div class="photo-slider-shell">
        <button
          class="slider-arrow slider-arrow-prev"
          type="button"
          aria-label="Previous photos"
          id={`${sliderId}-prev`}
        >
          <span aria-hidden="true">&#8592;</span>
        </button>
        <div
          class="photo-slider-track"
          id={sliderId}
          data-photo-slider
        >
          {items.map((item) => (
            <a class="photo-slide" href={item.href}>
              <img src={item.imageUrl} alt={item.imageAlt || ""} loading="lazy" />
            </a>
          ))}
        </div>
        <button
          class="slider-arrow slider-arrow-next"
          type="button"
          aria-label="Next photos"
          id={`${sliderId}-next`}
        >
          <span aria-hidden="true">&#8594;</span>
        </button>
      </div>
    </div>
  </section>
)}

<script is:inline define:vars={{ sliderId }}>
  (function () {
    var track = document.getElementById(sliderId);
    if (!track) return;

    var prevBtn = document.getElementById(sliderId + "-prev");
    var nextBtn = document.getElementById(sliderId + "-next");
    var autoTimer;

    // Add clones to both ends for infinite scroll illusion
    var slides = Array.prototype.slice.call(track.querySelectorAll(".photo-slide"));
    if (slides.length < 2) return;

    var cloneCount = 1;
    // Clone first N and last N slides
    var clonesHead = slides.slice(0, cloneCount).map(function (s) { return s.cloneNode(true); });
    var clonesTail = slides.slice(-cloneCount).map(function (s) { return s.cloneNode(true); });

    clonesHead.forEach(function (c) { track.appendChild(c); });
    clonesTail.forEach(function (c) { track.insertBefore(c, slides[0]); });

    // After prepending tails, slides shift to the right by cloneCount
    var realCount = slides.length;
    var realStart = cloneCount; // index of first real slide after prepending
    var total = track.querySelectorAll(".photo-slide").length;
    var realEnd = realStart + realCount - 1; // index of last real slide

    // Scroll track to show first real slide, skipping the prepended clones
    var allSlides = track.querySelectorAll(".photo-slide");
    var firstReal = allSlides[realStart];
    if (firstReal) {
      track.scrollLeft = firstReal.offsetLeft - track.offsetLeft;
    }

    function getSlideWidth() {
      var firstSlide = track.querySelector(".photo-slide");
      if (!firstSlide) return 300;
      var style = window.getComputedStyle(track);
      var gap = parseFloat(style.columnGap || style.gap || "0");
      return firstSlide.offsetWidth + gap;
    }

    function getCurrentIndex() {
      var sw = getSlideWidth();
      var idx = Math.round(track.scrollLeft / sw);
      // Clamp to real slide range
      if (idx < realStart) idx = realStart;
      if (idx > realEnd) idx = realEnd;
      return idx;
    }

    function goTo(index) {
      var allS = track.querySelectorAll(".photo-slide");
      var el = allS[index];
      if (!el) return;
      var targetLeft = el.offsetLeft - track.offsetLeft;
      track.scrollTo({ left: targetLeft, behavior: "smooth" });
    }

    function jumpTo(index) {
      var allS = track.querySelectorAll(".photo-slide");
      var el = allS[index];
      if (!el) return;
      track.scrollLeft = el.offsetLeft - track.offsetLeft;
    }

    function next() {
      var cur = getCurrentIndex();
      var nextIdx = cur + 1;
      if (nextIdx > realEnd) {
        // Past last real slide — go to first real with smooth, then jump
        goTo(realEnd);
        setTimeout(function () { jumpTo(realStart); }, 380);
      } else {
        goTo(nextIdx);
      }
    }

    function prev() {
      var cur = getCurrentIndex();
      var prevIdx = cur - 1;
      if (prevIdx < realStart) {
        // Past first real slide — go to last real with smooth, then jump
        goTo(realStart);
        setTimeout(function () { jumpTo(realEnd); }, 380);
      } else {
        goTo(prevIdx);
      }
    }

    function startAuto() {
      stopAuto();
      autoTimer = setInterval(next, 4200);
    }

    function stopAuto() {
      clearInterval(autoTimer);
    }

    // Scroll handler — detect when user lands in clone zone and silently jump back
    var jumping = false;
    track.addEventListener("scroll", function () {
      if (jumping) return;
      var allS = track.querySelectorAll(".photo-slide");
      var sw = getSlideWidth();

      // User scrolled into the prepended clone region (left of real slides)
      var lastCloneEl = allS[cloneCount - 1];
      if (lastCloneEl && track.scrollLeft < lastCloneEl.offsetLeft - track.offsetLeft - sw * 0.3) {
        jumping = true;
        jumpTo(realEnd);
        setTimeout(function () { jumping = false; }, 80);
        return;
      }

      // User scrolled into the appended clone region (right of real slides)
      var firstCloneEl = allS[total - cloneCount];
      if (firstCloneEl && track.scrollLeft > firstCloneEl.offsetLeft - track.offsetLeft + sw * 0.3) {
        jumping = true;
        jumpTo(realStart);
        setTimeout(function () { jumping = false; }, 80);
        return;
      }
    }, { passive: true });

    // Mouse hover pauses auto-advance
    track.addEventListener("mouseenter", stopAuto);
    track.addEventListener("mouseleave", startAuto);

    // Button clicks
    if (prevBtn) prevBtn.addEventListener("click", function () { stopAuto(); prev(); startAuto(); });
    if (nextBtn) nextBtn.addEventListener("click", function () { stopAuto(); next(); startAuto(); });

    startAuto();
  })();
</script>

<style>
  .photo-slider-section {
    padding-top: 0.35rem;
  }

  .photo-slider-shell {
    position: relative;
    display: grid;
    align-items: center;
  }

  .photo-slider-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(260px, 1fr);
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding: 0 3rem;
    scroll-behavior: smooth;
  }

  .photo-slider-track::-webkit-scrollbar {
    display: none;
  }

  .photo-slide {
    position: relative;
    display: block;
    aspect-ratio: 4 / 5;
    border-radius: calc(var(--radius) + 12px);
    overflow: hidden;
    scroll-snap-align: center;
    box-shadow: var(--shadow-soft);
    background: linear-gradient(135deg, #f0ece2 0%, #ded5c6 100%);
    border: 1px solid rgba(26, 60, 52, 0.1);
  }

  .photo-slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(12, 26, 23, 0.02) 0%, rgba(12, 26, 23, 0.12) 100%);
    pointer-events: none;
  }

  .photo-slide:hover,
  .photo-slide:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 32px 72px rgba(22, 37, 31, 0.16);
  }

  .photo-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 260ms ease;
  }

  .photo-slide:hover img,
  .photo-slide:focus-visible img {
    transform: scale(1.04);
  }

  .slider-arrow {
    position: absolute;
    top: 50%;
    z-index: 2;
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(26, 60, 52, 0.14);
    background: rgba(255, 252, 245, 0.92);
    color: var(--primary);
    box-shadow: 0 18px 40px rgba(22, 37, 31, 0.14);
    cursor: pointer;
    transform: translateY(-50%);
    backdrop-filter: blur(10px);
  }

  .slider-arrow:hover,
  .slider-arrow:focus-visible {
    background: rgba(255, 252, 245, 1);
  }

  .slider-arrow-prev {
    left: 0;
  }

  .slider-arrow-next {
    right: 0;
  }

  @media (max-width: 960px) {
    .photo-slider-track {
      grid-auto-columns: minmax(220px, 82vw);
      padding: 0 0.5rem;
    }

    .slider-arrow {
      display: none;
    }
  }
</style>
