---
type SliderItem = {
  href: string;
  imageUrl: string;
  imageAlt?: string;
};

type Props = {
  items: SliderItem[];
};

const { items } = Astro.props;
const sliderId = "homepage-photo-slider";
---

{items.length > 0 && (
  <section class="section photo-slider-section" aria-label="Featured travel photos">
    <div class="container">
      <div class="photo-slider-shell">
        <button
          class="slider-arrow slider-arrow-prev"
          type="button"
          aria-label="Previous photos"
          id={`${sliderId}-prev`}
        >
          <span aria-hidden="true">&#8592;</span>
        </button>
        <div
          class="photo-slider-track"
          id={sliderId}
          data-photo-slider
        >
          {items.map((item) => (
            <a class="photo-slide" href={item.href}>
              <img src={item.imageUrl} alt={item.imageAlt || ""} loading="lazy" />
            </a>
          ))}
        </div>
        <button
          class="slider-arrow slider-arrow-next"
          type="button"
          aria-label="Next photos"
          id={`${sliderId}-next`}
        >
          <span aria-hidden="true">&#8594;</span>
        </button>
      </div>
    </div>
  </section>
)}

<script is:inline define:vars={{ sliderId }}>
  (function () {
    var track = document.getElementById(sliderId);
    if (!track) return;

    var prevBtn = document.getElementById(sliderId + "-prev");
    var nextBtn = document.getElementById(sliderId + "-next");
    if (!prevBtn || !nextBtn) return;

    var isTransitioning = false;

    // Collect original slides
    var originalSlides = Array.prototype.slice.call(track.querySelectorAll(".photo-slide"));
    var REAL_COUNT = originalSlides.length;
    if (REAL_COUNT < 2) return;

    // Clone first and last slides for infinite loop illusion
    // Clones order: [lastClone, R0, R1, R2, R3, R4, firstClone]
    var lastClone = originalSlides[REAL_COUNT - 1].cloneNode(true);
    var firstClone = originalSlides[0].cloneNode(true);
    track.insertBefore(lastClone, track.firstChild);
    track.appendChild(firstClone);

    // Re-query all slides including clones
    var allSlides = track.querySelectorAll(".photo-slide");
    var TOTAL = allSlides.length; // REAL_COUNT + 2

    var REAL_START = 1;
    var REAL_END = TOTAL - 2;

    // Compute stride from actual DOM positions
    var STRIDE = allSlides[REAL_START + 1].offsetLeft - allSlides[REAL_START].offsetLeft;

    // State: current logical index in the allSlides array
    var currentIdx = REAL_START;

    // Get exact pixel offset for slide index
    function getOffset(idx) {
      return allSlides[idx].offsetLeft - track.offsetLeft;
    }

    // Force reflow to ensure scrollLeft write takes effect immediately
    function forceReflow() {
      void track.offsetWidth;
    }

    // Instant jump to any slide index
    function jumpToIdx(idx) {
      if (isTransitioning) return;
      idx = Math.max(0, Math.min(TOTAL - 1, idx));
      currentIdx = idx;
      track.scrollLeft = getOffset(idx);
      forceReflow();
    }

    // Next: advance one real slide, loop from end to start
    function goToNext() {
      var nextIdx = currentIdx + 1;
      if (nextIdx > REAL_END) {
        jumpToIdx(REAL_START); // seamless loop back
      } else {
        jumpToIdx(nextIdx);
      }
    }

    // Prev: go back one real slide, loop from start to end
    function goToPrev() {
      var prevIdx = currentIdx - 1;
      if (prevIdx < REAL_START) {
        jumpToIdx(REAL_END); // seamless loop to last
      } else {
        jumpToIdx(prevIdx);
      }
    }

    // Button handlers
    prevBtn.addEventListener("click", function () {
      goToPrev();
    });

    nextBtn.addEventListener("click", function () {
      goToNext();
    });

    // Init: scroll to first real slide
    jumpToIdx(REAL_START);
  })();
</script>

<style>
  .photo-slider-section {
    padding-top: 0.35rem;
  }

  .photo-slider-shell {
    position: relative;
    display: grid;
    align-items: center;
  }

  .photo-slider-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(260px, 1fr);
    gap: 1rem;
    overflow-x: auto;
    /* No scroll-snap — JS controls exact positions */
    scrollbar-width: none;
    padding: 0 3rem;
    /* Override global html{scroll-behavior:smooth} */
    scroll-behavior: auto;
  }

  .photo-slider-track::-webkit-scrollbar {
    display: none;
  }

  .photo-slide {
    position: relative;
    display: block;
    aspect-ratio: 4 / 5;
    border-radius: calc(var(--radius) + 12px);
    overflow: hidden;
    /* No scroll-snap — JS controls exact positions */
    scroll-snap-align: none;
    box-shadow: var(--shadow-soft);
    background: linear-gradient(135deg, #f0ece2 0%, #ded5c6 100%);
    border: 1px solid rgba(26, 60, 52, 0.1);
  }

  .photo-slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(12, 26, 23, 0.02) 0%, rgba(12, 26, 23, 0.12) 100%);
    pointer-events: none;
  }

  .photo-slide:hover,
  .photo-slide:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 32px 72px rgba(22, 37, 31, 0.16);
  }

  .photo-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 260ms ease;
  }

  .photo-slide:hover img,
  .photo-slide:focus-visible img {
    transform: scale(1.04);
  }

  .slider-arrow {
    position: absolute;
    top: 50%;
    z-index: 2;
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(26, 60, 52, 0.14);
    background: rgba(255, 252, 245, 0.92);
    color: var(--primary);
    box-shadow: 0 18px 40px rgba(22, 37, 31, 0.14);
    cursor: pointer;
    transform: translateY(-50%);
    backdrop-filter: blur(10px);
  }

  .slider-arrow:hover,
  .slider-arrow:focus-visible {
    background: rgba(255, 252, 245, 1);
  }

  .slider-arrow-prev {
    left: 0;
  }

  .slider-arrow-next {
    right: 0;
  }

  @media (max-width: 960px) {
    .photo-slider-track {
      grid-auto-columns: minmax(220px, 82vw);
      padding: 0 0.5rem;
    }

    .slider-arrow {
      display: none;
    }
  }
</style>
