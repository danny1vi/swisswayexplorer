---
type SliderItem = {
  href: string;
  imageUrl: string;
  imageAlt?: string;
};

type Props = {
  items: SliderItem[];
};

const { items } = Astro.props;
const sliderId = "homepage-photo-slider";
---

{items.length > 0 && (
  <section class="section photo-slider-section" aria-label="Featured travel photos">
    <div class="container">
      <div class="photo-slider-shell">
        <button class="slider-arrow slider-arrow-prev" type="button" aria-label="Previous photos" data-slider-prev={sliderId}>
          <span aria-hidden="true">←</span>
        </button>
        <div class="photo-slider-track" id={sliderId} data-photo-slider>
          {items.map((item) => (
            <a class="photo-slide" href={item.href}>
              <img src={item.imageUrl} alt={item.imageAlt || ""} loading="lazy" />
            </a>
          ))}
        </div>
        <button class="slider-arrow slider-arrow-next" type="button" aria-label="Next photos" data-slider-next={sliderId}>
          <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>
  </section>
)}

<script is:inline define:vars={{ sliderId }}>
  const track = document.getElementById(sliderId);
  const prevButton = document.querySelector(`[data-slider-prev="${sliderId}"]`);
  const nextButton = document.querySelector(`[data-slider-next="${sliderId}"]`);

  if (track instanceof HTMLElement) {
    const slideWidth = () => {
      const firstSlide = track.querySelector(".photo-slide");
      if (!(firstSlide instanceof HTMLElement)) return track.clientWidth * 0.82;
      const style = window.getComputedStyle(track);
      const gap = Number.parseFloat(style.columnGap || style.gap || "0");
      return firstSlide.offsetWidth + gap;
    };

    const move = (direction) => {
      track.scrollBy({ left: slideWidth() * direction, behavior: "smooth" });
    };

    prevButton?.addEventListener("click", () => move(-1));
    nextButton?.addEventListener("click", () => move(1));

    let autoAdvance = window.setInterval(() => move(1), 4200);
    const stop = () => window.clearInterval(autoAdvance);
    const start = () => {
      stop();
      autoAdvance = window.setInterval(() => move(1), 4200);
    };

    const maybeLoop = () => {
      const maxScrollLeft = track.scrollWidth - track.clientWidth;
      if (track.scrollLeft >= maxScrollLeft - 8) {
        track.scrollTo({ left: 0, behavior: "smooth" });
      }
    };

    track.addEventListener("scroll", maybeLoop, { passive: true });
    track.addEventListener("mouseenter", stop);
    track.addEventListener("mouseleave", start);
    track.addEventListener("focusin", stop);
    track.addEventListener("focusout", start);

    start();
  }
</script>

<style>
  .photo-slider-section {
    padding-top: 0.35rem;
  }

  .photo-slider-shell {
    position: relative;
    display: grid;
    align-items: center;
  }

  .photo-slider-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(260px, 1fr);
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding: 0 3rem;
    scroll-behavior: smooth;
  }

  .photo-slider-track::-webkit-scrollbar {
    display: none;
  }

  .photo-slide {
    position: relative;
    display: block;
    aspect-ratio: 4 / 5;
    border-radius: calc(var(--radius) + 12px);
    overflow: hidden;
    scroll-snap-align: center;
    box-shadow: var(--shadow-soft);
    background: linear-gradient(135deg, #f0ece2 0%, #ded5c6 100%);
    border: 1px solid rgba(26, 60, 52, 0.1);
  }

  .photo-slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(12, 26, 23, 0.02) 0%, rgba(12, 26, 23, 0.12) 100%);
    pointer-events: none;
  }

  .photo-slide:hover,
  .photo-slide:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 32px 72px rgba(22, 37, 31, 0.16);
  }

  .photo-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 260ms ease;
  }

  .photo-slide:hover img,
  .photo-slide:focus-visible img {
    transform: scale(1.04);
  }

  .slider-arrow {
    position: absolute;
    top: 50%;
    z-index: 2;
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(26, 60, 52, 0.14);
    background: rgba(255, 252, 245, 0.92);
    color: var(--primary);
    box-shadow: 0 18px 40px rgba(22, 37, 31, 0.14);
    cursor: pointer;
    transform: translateY(-50%);
    backdrop-filter: blur(10px);
  }

  .slider-arrow:hover,
  .slider-arrow:focus-visible {
    background: rgba(255, 252, 245, 1);
  }

  .slider-arrow-prev {
    left: 0;
  }

  .slider-arrow-next {
    right: 0;
  }

  @media (max-width: 960px) {
    .photo-slider-track {
      grid-auto-columns: minmax(220px, 82vw);
      padding: 0 0.5rem;
    }

    .slider-arrow {
      display: none;
    }
  }
</style>
