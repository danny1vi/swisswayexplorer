---
type Props = {
  eyebrow: string;
  heading: string;
  description: string;
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
};

const { eyebrow, heading, description, primaryCta, secondaryCta } = Astro.props;
---

<section class="hero-section">
  <div class="hero-bg"></div>
  <div class="container">
    <div class="hero card">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{heading}</h1>
      <p class="summary">{description}</p>
      <div class="actions">
        <a class="btn btn-primary" href={primaryCta.href}>{primaryCta.label}</a>
        <a class="btn btn-secondary" href={secondaryCta.href}>{secondaryCta.label}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    padding: 2rem 0 3rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(15, 107, 154, 0.08) 0%, transparent 60%),
      linear-gradient(180deg, rgba(205, 225, 245, 0.3) 0%, var(--bg) 100%);
    z-index: 0;
    pointer-events: none;
  }

  .hero-section .container {
    position: relative;
    z-index: 1;
  }

  .hero {
    padding: clamp(2rem, 5vw, 3.5rem);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border);
  }

  .eyebrow {
    margin: 0;
    color: var(--primary);
    font-size: 0.82rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0.5rem 0 0;
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.15;
    max-width: 18ch;
    color: var(--text);
  }

  .summary {
    margin: 1rem 0 0;
    max-width: 65ch;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .actions {
    margin-top: 1.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 1.5rem;
    }
  }
</style>
