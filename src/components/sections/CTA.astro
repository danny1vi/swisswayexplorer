---
type Props = {
  heading: string;
  description: string;
  action: { label: string; href: string };
};

const { heading, description, action } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="card cta">
      <div>
        <p class="section-label">Next Step</p>
        <h2>{heading}</h2>
        <p>{description}</p>
      </div>
      <a class="btn btn-primary" href={action.href}>{action.label}</a>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background:
      radial-gradient(circle at top right, rgba(201, 168, 76, 0.16), transparent 32%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.92));
  }

  .cta h2 {
    margin: 0.25rem 0 0;
    font-size: clamp(1.7rem, 3vw, 2.2rem);
  }

  .cta p {
    margin: 0.45rem 0 0;
    color: var(--muted);
    max-width: 58ch;
    line-height: 1.75;
  }

  @media (max-width: 760px) {
    .cta {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
