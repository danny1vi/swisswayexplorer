---
import { truncateText } from "../../lib/truncate";

type Teaser = {
  duration?: string;
  title: string;
  description: string;
  href: string;
  imageUrl?: string;
  imageAlt?: string;
};

type Props = {
  items: Teaser[];
};

const { items } = Astro.props;
---

<section class="section itinerary-section">
  <div class="container">
    <div class="section-heading">
      <p class="section-label">Quick Formats</p>
      <h2 class="section-title">Use tighter editorial formats when you only need the next decision, not a full route rewrite.</h2>
      <p class="section-copy">
        These cards are designed for short planning windows: arrival days, transfer days, and pass decisions.
      </p>
    </div>
    <div class="teaser-grid">
      {items.map((item, index) => (
        <a class:list={["teaser-card card", index === 0 && "teaser-card-featured"]} href={item.href}>
          {item.imageUrl && (
            <div class="teaser-media">
              <img src={item.imageUrl} alt={item.imageAlt || item.title} loading="lazy" />
            </div>
          )}
          <div class="teaser-copy">
            {item.duration && <p class="duration">{item.duration}</p>}
            <h3>{item.title}</h3>
            <p>{truncateText(item.description, 100)}</p>
            <span class="teaser-link">Read guide</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .itinerary-section {
    padding-top: 1rem;
  }

  .section-heading {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    max-width: 62rem;
  }

  .teaser-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .teaser-card {
    padding: 0;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    text-decoration: none;
    color: inherit;
    min-height: 100%;
  }

  .teaser-card:hover,
  .teaser-card:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 28px 64px rgba(22, 37, 31, 0.12);
  }

  .teaser-card-featured {
    grid-column: span 2;
    grid-template-columns: minmax(220px, 0.95fr) minmax(0, 1.05fr);
  }

  .teaser-media {
    display: block;
    min-height: 100%;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #f0ece2 0%, #ded5c6 100%);
  }

  .teaser-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 220ms ease;
  }

  .teaser-copy {
    display: grid;
    gap: 0.85rem;
    padding: 1.35rem;
  }

  .teaser-card:hover .teaser-media img,
  .teaser-card:focus-visible .teaser-media img {
    transform: scale(1.04);
  }

  .teaser-media::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 30%;
    background: linear-gradient(180deg, rgba(14, 30, 26, 0) 0%, rgba(14, 30, 26, 0.22) 100%);
    pointer-events: none;
  }

  .duration {
    margin: 0;
    display: inline-flex;
    width: fit-content;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    background: rgba(201, 168, 76, 0.14);
    color: var(--primary);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  .teaser-card h3 {
    margin: 0;
    font-size: 1.42rem;
    line-height: 1.1;
    max-width: 18ch;
  }

  .teaser-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .teaser-link {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.35rem;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.92rem;
  }

  .teaser-link::after {
    content: "->";
    transition: transform 200ms ease;
  }

  .teaser-card:hover .teaser-link::after,
  .teaser-card:focus-visible .teaser-link::after {
    transform: translateX(2px);
  }

  @media (max-width: 980px) {
    .teaser-grid {
      grid-template-columns: 1fr;
    }

    .teaser-card {
      grid-template-columns: 1fr;
    }

    .teaser-card-featured {
      grid-column: span 1;
      grid-template-columns: 1fr;
    }

    .teaser-media {
      aspect-ratio: 16 / 9;
    }
  }
</style>
