---
import { truncateText } from "../../lib/truncate";

type Props = {
  eyebrow?: string;
  title: string;
  description: string;
  body?: string;
  cta?: {
    label: string;
    href: string;
  };
  image?: {
    url: string;
    alt?: string;
  };
  imageSide?: "left" | "right";
  relatedStories?: Array<{
    eyebrow?: string;
    title: string;
    summary: string;
    href: string;
    imageUrl?: string;
    imageAlt?: string;
  }>;
};

const { eyebrow, title, description, body, cta, image, imageSide = "left", relatedStories = [] } = Astro.props;
const paragraphs = (body || "")
  .split(/\n+/)
  .map((item) => item.trim())
  .filter(Boolean);
---

<section class="section">
  <div class="container">
    <article class:list={["editorial-split", imageSide === "right" && "is-reversed"]}>
      <div class="editorial-media">
        {image?.url ? (
          <img src={image.url} alt={image.alt || title} loading="lazy" />
        ) : (
          <div class="editorial-placeholder" aria-hidden="true"></div>
        )}
      </div>
      <div class="editorial-copy">
        {eyebrow && <p class="section-label">{eyebrow}</p>}
        <h2 class="section-title">{title}</h2>
        <p class="lead">{description}</p>
        {paragraphs.map((paragraph) => (
          <p class="detail">{paragraph}</p>
        ))}
        {cta?.href && cta?.label && (
          <a class="btn btn-primary" href={cta.href}>
            {cta.label}
          </a>
        )}
      </div>
    </article>
  </div>
</section>

{relatedStories.length > 0 && (
  <section class="section editorial-related-section">
    <div class="container">
      <div class="editorial-related-grid">
        {relatedStories.map((item) => (
          <a class="editorial-related-card card" href={item.href}>
            {item.imageUrl && (
              <div class="editorial-related-media">
                <img src={item.imageUrl} alt={item.imageAlt || item.title} loading="lazy" />
              </div>
            )}
            <div class="editorial-related-copy">
              {item.eyebrow && <p class="editorial-related-eyebrow">{item.eyebrow}</p>}
              <h3>{item.title}</h3>
              <p>{truncateText(item.summary, 100)}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .editorial-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 4vw, 2.5rem);
    align-items: stretch;
  }

  .editorial-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    padding: clamp(0.5rem, 2vw, 1rem) 0;
  }

  .editorial-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: calc(var(--radius) + 2px);
    border: 1px solid rgba(26, 60, 52, 0.12);
    box-shadow: var(--shadow-soft);
    background: linear-gradient(135deg, #f0ece2 0%, #ded5c6 100%);
  }

  .editorial-media img,
  .editorial-placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .lead,
  .detail {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--text);
    max-width: 30rem;
  }

  .detail {
    max-width: 34rem;
  }

  .editorial-copy .btn {
    margin-top: 0.5rem;
    align-self: flex-start;
  }

  .editorial-related-section {
    padding-top: 0.25rem;
  }

  .editorial-related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .editorial-related-card {
    display: grid;
    gap: 0.95rem;
    text-decoration: none;
    color: inherit;
    padding: 0;
    overflow: hidden;
  }

  .editorial-related-media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: linear-gradient(135deg, #f0ece2 0%, #ded5c6 100%);
  }

  .editorial-related-media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 240ms ease;
  }

  .editorial-related-card:hover .editorial-related-media img,
  .editorial-related-card:focus-visible .editorial-related-media img {
    transform: scale(1.04);
  }

  .editorial-related-copy {
    display: grid;
    gap: 0.5rem;
    padding: 0 1rem 1rem;
  }

  .editorial-related-eyebrow {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--primary);
  }

  .editorial-related-copy h3,
  .editorial-related-copy p {
    margin: 0;
  }

  .editorial-related-copy h3 {
    font-size: 1.2rem;
    line-height: 1.08;
  }

  .editorial-related-copy p {
    color: var(--muted);
    line-height: 1.68;
  }

  @media (max-width: 900px) {
    .editorial-related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
