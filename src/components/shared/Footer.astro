---
import { siteConfig } from "../../config/site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-wrap">
    <div class="footer-brand">
      <a class="footer-logo" href="/">{siteConfig.name}</a>
      <p class="footer-tagline">{siteConfig.tagline}</p>
    </div>
    <div class="footer-links">
      <div class="footer-col">
        <h4>Explore</h4>
        {siteConfig.nav.slice(0, 2).map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
      <div class="footer-col">
        <h4>Info</h4>
        {siteConfig.nav.slice(2).map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
        <a href="/privacy/">Privacy</a>
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {year} {siteConfig.name}. Built for clearer Swiss route decisions.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background:
      linear-gradient(180deg, rgba(255, 252, 245, 0.45), rgba(255, 252, 245, 0.85)),
      var(--surface-strong);
    margin-top: 3rem;
  }

  .footer-wrap {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 3rem 0 2rem;
  }

  .footer-logo {
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-heading);
    font-size: 1.7rem;
    line-height: 1;
  }

  .footer-tagline {
    margin: 0.75rem 0 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.8;
    max-width: 24rem;
  }

  .footer-links {
    display: flex;
    gap: 3.5rem;
  }

  .footer-col h4 {
    margin: 0 0 0.75rem;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--primary);
    font-weight: 800;
  }

  .footer-col a {
    display: block;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.96rem;
    padding: 0.28rem 0;
  }

  .footer-col a:hover,
  .footer-col a:focus-visible {
    color: var(--text);
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: 1rem 0 1.35rem;
    text-align: center;
    font-size: 0.82rem;
    color: var(--muted);
  }

  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 760px) {
    .footer-wrap {
      flex-direction: column;
      padding: 2.25rem 0 1.5rem;
      gap: 1.8rem;
    }

    .footer-links {
      gap: 2.5rem;
    }
  }
</style>
