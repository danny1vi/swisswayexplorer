---
import { siteConfig } from "../../config/site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-wrap">
    <div class="footer-brand">
      <a class="footer-logo" href="/">{siteConfig.name}</a>
      <p class="footer-tagline">{siteConfig.tagline}</p>
    </div>
    <div class="footer-links">
      <div class="footer-col">
        <h4>Explore</h4>
        {siteConfig.nav.slice(0, 2).map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
      <div class="footer-col">
        <h4>Info</h4>
        {siteConfig.nav.slice(2).map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
        <a href="/privacy">Privacy</a>
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {year} {siteConfig.name}. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--surface);
    margin-top: 3rem;
  }

  .footer-wrap {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 2.5rem 0 2rem;
  }

  .footer-logo {
    color: var(--text);
    text-decoration: none;
    font-weight: 800;
    font-size: 1.15rem;
  }

  .footer-tagline {
    margin: 0.4rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
    max-width: 280px;
  }

  .footer-links {
    display: flex;
    gap: 3rem;
  }

  .footer-col h4 {
    margin: 0 0 0.6rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text);
  }

  .footer-col a {
    display: block;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.92rem;
    padding: 0.25rem 0;
    transition: color 0.15s ease;
  }

  .footer-col a:hover {
    color: var(--primary);
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: 1rem 0;
    text-align: center;
    font-size: 0.82rem;
    color: var(--muted);
  }

  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 760px) {
    .footer-wrap {
      flex-direction: column;
      padding: 2rem 0 1.5rem;
      gap: 1.5rem;
    }

    .footer-links {
      gap: 2rem;
    }
  }
</style>
