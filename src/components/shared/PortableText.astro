---
import type { BodyBlock } from "../../lib/sanity/types";

type Props = {
  blocks?: BodyBlock[];
};

const { blocks } = Astro.props;

if (!blocks || blocks.length === 0) {
  return null;
}

function escapeHtml(text: string): string {
  return text
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function renderSpan(span: any): string {
  if (span._type !== "span") return "";
  let text: string = escapeHtml(span.text || "");
  const marks: string[] = span.marks || [];
  const markDefs: any[] = span.markDefs || [];

  if (marks.includes("strong")) {
    text = `<strong>${text}</strong>`;
  }
  if (marks.includes("em")) {
    text = `<em>${text}</em>`;
  }

  for (const markKey of marks) {
    const markDef = markDefs.find((m) => m._key === markKey && m._type === "link");
    if (markDef && markDef.href) {
      const isExternal =
        markDef.href.startsWith("http://") || markDef.href.startsWith("https://");
      const target = isExternal ? ' target="_blank" rel="noopener noreferrer"' : "";
      text = `<a href="${escapeHtml(markDef.href)}"${target}>${text}</a>`;
    }
  }

  return text;
}
---

<div class="portable-text">
  {blocks.map((block) => {
    if (block._type === "image" && block.url) {
      return (
        <figure class="portable-image">
          <img src={block.url} alt={block.alt || ""} loading="lazy" />
          {block.caption && <figcaption>{block.caption}</figcaption>}
        </figure>
      );
    }

    if (block._type !== "block") return null;

    const children = block.children || [];
    const html = children.map((child: any) => renderSpan(child)).join("");
    const Tag = block.style === "h2" ? "h2" : block.style === "h3" ? "h3" : "p";

    return <Tag set:html={html} />;
  })}
</div>

<style>
  .portable-text {
    margin-top: 1.5rem;
  }

  .portable-text h2 {
    margin: 1.5rem 0 0.5rem;
    font-size: 1.2rem;
    color: var(--text);
  }

  .portable-text h3 {
    margin: 1.2rem 0 0.4rem;
    font-size: 1.05rem;
    color: var(--text);
  }

  .portable-text p {
    margin: 0.7rem 0 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .portable-text p:first-child,
  .portable-text h2:first-child,
  .portable-text h3:first-child {
    margin-top: 0;
  }

  .portable-text a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .portable-text a:hover {
    color: var(--accent-amber);
  }

  .portable-image {
    margin: 1.35rem 0 0;
  }

  .portable-text .portable-image img {
    width: 100%;
    display: block;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--bg);
  }

  .portable-text .portable-image figcaption {
    margin-top: 0.55rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
</style>
