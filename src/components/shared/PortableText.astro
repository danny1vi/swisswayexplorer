---
import type { BodyBlock } from "../../lib/sanity/types";

type Props = {
  blocks?: BodyBlock[];
  variant?: "default" | "readable";
};

const { blocks, variant = "default" } = Astro.props;

if (!blocks || blocks.length === 0) {
  return null;
}

function escapeHtml(text: string): string {
  return text
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function renderSpan(span: any, markDefs: any[]): string {
  if (span._type !== "span") return "";
  let text: string = escapeHtml(span.text || "");
  const marks: string[] = span.marks || [];

  if (marks.includes("strong")) {
    text = `<strong>${text}</strong>`;
  }
  if (marks.includes("em")) {
    text = `<em>${text}</em>`;
  }

  for (const markKey of marks) {
    const markDef = markDefs.find((m) => m._key === markKey && m._type === "link");
    if (markDef && markDef.href) {
      const isExternal =
        markDef.href.startsWith("http://") || markDef.href.startsWith("https://");
      const target = isExternal ? ' target="_blank" rel="noopener noreferrer"' : "";
      text = `<a href="${escapeHtml(markDef.href)}"${target}>${text}</a>`;
    }
  }

  return text;
}
---

<div class:list={["portable-text", variant === "readable" && "portable-text-readable"]}>
  {blocks.map((block) => {
    if (block._type === "quickVerdict") {
      return (
        <section class="quick-verdict">
          {block.eyebrow && <p class="quick-verdict-eyebrow">{block.eyebrow}</p>}
          <h3>{block.title}</h3>
          <p>{block.body}</p>
        </section>
      );
    }

    if (block._type === "highlightBox") {
      return (
        <aside class:list={["highlight-box", `highlight-${block.tone || "tip"}`]}>
          <div class="highlight-label">{block.tone || "tip"}</div>
          {block.title && <h3>{block.title}</h3>}
          <p>{block.body}</p>
        </aside>
      );
    }

    if (block._type === "image" && block.url) {
      return (
        <figure class="portable-image">
          <img src={block.url} alt={block.alt || ""} loading="lazy" />
          {block.caption && <figcaption>{block.caption}</figcaption>}
        </figure>
      );
    }

    if (block._type !== "block") return null;

    const children = block.children || [];
    const markDefs: any[] = block.markDefs || [];
    const html = children.map((child: any) => renderSpan(child, markDefs)).join("");
    const style = block.style || "normal";
    const Tag = style === "h2" ? "h2" : style === "h3" ? "h3" : style === "blockquote" ? "blockquote" : "p";
    const alignClass =
      style === "bodyLeft"
        ? "align-left"
        : style === "bodyCenter"
          ? "align-center"
          : style === "bodyRight"
            ? "align-right"
            : style === "bodyJustify" || style === "normal"
              ? "align-justify"
              : undefined;

    return <Tag class={alignClass} set:html={html} />;
  })}
</div>

<style>
  .portable-text {
    margin-top: 1.5rem;
  }

  .portable-text h2 {
    margin: 1.5rem 0 0.5rem;
    font-size: 1.2rem;
    color: var(--text);
  }

  .portable-text h3 {
    margin: 1.2rem 0 0.4rem;
    font-size: 1.05rem;
    color: var(--text);
  }

  .portable-text p {
    margin: 0.7rem 0 0;
    color: var(--muted);
    line-height: 1.7;
    text-align: justify;
    text-justify: inter-word;
  }

  .portable-text-readable p {
    font-family: var(--font-body);
    font-size: 1.03rem;
    line-height: 1.82;
    color: #334037;
    max-width: 68ch;
    text-wrap: pretty;
  }

  .portable-text p:first-child,
  .portable-text h2:first-child,
  .portable-text h3:first-child {
    margin-top: 0;
  }

  .portable-text-readable h2 {
    font-family: var(--font-reading);
    font-size: 1.42rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.46;
    margin: 2rem 0 0.68rem;
  }

  .portable-text-readable h3 {
    font-family: var(--font-reading);
    font-size: 1.12rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.4;
  }

  .portable-text a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .portable-text a:hover {
    color: var(--accent-amber);
  }

  .portable-text .align-left {
    text-align: left;
  }

  .portable-text .align-center {
    text-align: center;
    text-wrap: balance;
  }

  .portable-text .align-right {
    text-align: right;
  }

  .portable-text .align-justify {
    text-align: justify;
    text-justify: inter-word;
  }

  .portable-text blockquote {
    margin: 1.2rem 0 0;
    padding: 0.1rem 0 0.1rem 1rem;
    border-left: 4px solid rgba(26, 60, 52, 0.18);
    color: #415045;
    font-style: italic;
  }

  .portable-image {
    margin: 1.35rem 0 0;
  }

  .quick-verdict,
  .highlight-box {
    margin-top: 1.35rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-soft);
  }

  .quick-verdict {
    padding: 1rem 1.1rem 1.1rem;
    background:
      linear-gradient(160deg, rgba(26, 60, 52, 0.98) 0%, rgba(39, 84, 73, 0.94) 100%);
    color: rgba(255, 249, 240, 0.98);
  }

  .quick-verdict-eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(229, 195, 113, 0.92);
  }

  .portable-text .quick-verdict h3 {
    margin: 0;
    color: inherit;
    font-size: 1.1rem;
  }

  .portable-text .quick-verdict p {
    margin-top: 0.6rem;
    color: rgba(255, 249, 240, 0.92);
  }

  .portable-text-readable .quick-verdict h3,
  .portable-text-readable .highlight-box h3,
  .portable-text-readable .quick-verdict p,
  .portable-text-readable .highlight-box p,
  .portable-text-readable .portable-image figcaption {
    font-family: var(--font-body);
  }

  .highlight-box {
    position: relative;
    padding: 1rem 1.1rem 1rem 1.2rem;
    background: rgba(251, 247, 238, 0.96);
    overflow: hidden;
  }

  .highlight-box::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 6px;
    background: var(--primary);
  }

  .highlight-label {
    display: inline-flex;
    margin-bottom: 0.55rem;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(26, 60, 52, 0.08);
    color: var(--primary);
  }

  .portable-text .highlight-box h3 {
    margin: 0;
    font-size: 1.02rem;
  }

  .portable-text .highlight-box p {
    margin-top: 0.45rem;
  }

  .highlight-important {
    background: rgba(255, 245, 228, 0.98);
  }

  .highlight-important::before {
    background: #d07a18;
  }

  .highlight-important .highlight-label {
    background: rgba(208, 122, 24, 0.12);
    color: #9a5709;
  }

  .highlight-budget {
    background: rgba(244, 250, 245, 0.98);
  }

  .highlight-budget::before {
    background: #3d7a52;
  }

  .highlight-budget .highlight-label {
    background: rgba(61, 122, 82, 0.12);
    color: #2a5f3d;
  }

  .highlight-route {
    background: rgba(242, 246, 251, 0.98);
  }

  .highlight-route::before {
    background: #4d658a;
  }

  .highlight-route .highlight-label {
    background: rgba(77, 101, 138, 0.12);
    color: #3a4f73;
  }

  .portable-text .portable-image img {
    width: 100%;
    display: block;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--bg);
  }

  .portable-text .portable-image figcaption {
    margin-top: 0.55rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
</style>
