---
import Header from "../components/shared/Header.astro";
import Footer from "../components/shared/Footer.astro";
import { siteConfig } from "../config/site";
import { getSiteSettings } from "../lib/sanity/content";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  jsonld?: string;
};

const { title, description, image, imageAlt } = Astro.props;
const siteSettings = await getSiteSettings();
const resolvedTitle = title || siteSettings?.defaultSeo?.title || siteConfig.seo.title;
const resolvedDescription = description || siteSettings?.defaultSeo?.description || siteConfig.seo.description;
const siteName = siteSettings?.siteName || siteConfig.name;
const canonicalUrl = new URL(Astro.url.pathname, `https://${siteConfig.domain}`).toString();
const resolveAbsoluteAssetUrl = (value?: string) =>
  value ? new URL(value, `https://${siteConfig.domain}`).toString() : undefined;
const ogImage = resolveAbsoluteAssetUrl(image) || siteSettings?.ogImage?.url || `https://${siteConfig.domain}/og-default.svg`;
const ogImageAlt = imageAlt || siteSettings?.ogImage?.alt || `${siteName} social preview`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={resolvedDescription} />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="Qn3igouja5fBYihMg4nzh_8jcs9TPqX_WXEAmEvlz48" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{resolvedTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {Astro.props.jsonld && (
      <script type="application/ld+json" set:html={Astro.props.jsonld} />
    )}
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
    <!-- End Google Analytics -->
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Merriweather:wght@400;700&display=swap");

  :root {
    --bg: #f6f1e8;
    --surface: rgba(255, 252, 245, 0.9);
    --surface-strong: #fffdf8;
    --text: #16251f;
    --muted: #5f6c62;
    --primary: #1a3c34;
    --primary-strong: #102c26;
    --border: rgba(26, 60, 52, 0.14);
    --radius: 22px;
    --max: 1180px;
    --accent-blue: #4c8191;
    --accent-green: #52755b;
    --accent-amber: #c9a84c;
    --accent-purple: #75608b;
    --shadow-soft: 0 24px 60px rgba(22, 37, 31, 0.09);
    --font-heading: "Merriweather", Georgia, serif;
    --font-body: "Inter", "Segoe UI", sans-serif;
    --font-reading: "Merriweather", Georgia, serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: auto;
  }

  body {
    margin: 0;
    font-family: var(--font-body);
    color: var(--text);
    background:
      radial-gradient(1200px 500px at 92% -8%, rgba(201, 168, 76, 0.16) 0%, transparent 58%),
      radial-gradient(900px 420px at -12% 0%, rgba(26, 60, 52, 0.08) 0%, transparent 52%),
      linear-gradient(180deg, #fbf8f1 0%, var(--bg) 28%, #f4ede1 100%);
    line-height: 1.5;
    min-height: 100vh;
  }

  main {
    display: block;
    overflow: clip;
  }

  img {
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--text);
  }

  h1 {
    letter-spacing: -0.015em;
    line-height: 1.16;
  }

  h2 {
    letter-spacing: -0.005em;
    line-height: 1.22;
  }

  h3 {
    letter-spacing: -0.005em;
    line-height: 1.24;
  }

  h4,
  h5,
  h6 {
    letter-spacing: 0;
  }

  p {
    font-family: var(--font-body);
  }

  a {
    color: inherit;
  }

  a,
  button {
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  :focus-visible {
    outline: 2px solid rgba(201, 168, 76, 0.9);
    outline-offset: 3px;
  }

  .container {
    width: min(var(--max), calc(100% - 2rem));
    margin: 0 auto;
  }

  .section {
    padding: clamp(2.5rem, 7vw, 5.75rem) 0;
  }

  .section-label {
    margin: 0;
    color: var(--primary);
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 800;
  }

  .section-title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 0.98;
    max-width: 12ch;
  }

  .section-copy {
    margin: 0;
    color: var(--muted);
    max-width: 60ch;
    line-height: 1.8;
  }

  .card {
    background: linear-gradient(180deg, rgba(255, 252, 245, 0.92), rgba(255, 252, 245, 0.82));
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(10px);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 999px;
    border: 1px solid transparent;
    padding: 0.8rem 1.2rem;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.01em;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--primary);
    color: #fffaf1;
    box-shadow: 0 12px 24px rgba(26, 60, 52, 0.16);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background: var(--primary-strong);
    transform: translateY(-1px);
  }

  .btn-secondary {
    border-color: rgba(26, 60, 52, 0.2);
    color: var(--text);
    background: rgba(255, 252, 245, 0.72);
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    border-color: rgba(26, 60, 52, 0.38);
    background: rgba(255, 252, 245, 0.96);
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }

    .card:hover,
    .btn:hover {
      transform: none;
    }
  }
</style>
