---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDestinationBySlug } from "../../lib/sanity/content";
import PortableText from "../../components/shared/PortableText.astro";
import ImageGallery from "../../components/shared/ImageGallery.astro";
import { resolveDestinationImage } from "../../lib/contentImages";

const { slug = "" } = Astro.params;
const destination = await getDestinationBySlug(slug);
const destinationImage = resolveDestinationImage(destination);

if (!destination) {
  Astro.response.status = 404;
}

const destinationJsonLd = destination ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "TouristDestination",
  "name": destination.title,
  "description": destination.summary,
  "url": `https://swisswayexplorer.com/destinations/${destination.slug}/`,
  "image": destinationImage?.url ? [destinationImage.url] : [],
  "geo": destination.geo ? {
    "@type": "GeoCoordinates",
    "latitude": destination.geo.lat,
    "longitude": destination.geo.lng
  } : undefined,
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "CH"
  }
}) : undefined;
---

<BaseLayout
  title={`${destination?.title || "Destination not found"} | SwissWayExplorer`}
  description={destination?.summary || "Destination brief is not available yet."}
  image={destinationImage?.url}
  imageAlt={destinationImage?.alt}
  jsonld={destinationJsonLd}
>
  <section class="section">
    <div class="container">
      {
        destination ? (
          <article class="card detail">
            {destinationImage ? (
              <div class="hero-image">
                <img src={destinationImage.url} alt={destinationImage.alt || destination.title} />
              </div>
            ) : (
              <div class="hero-image hero-image-placeholder" aria-hidden="true">
                <span>{destination.title}</span>
              </div>
            )}
            <div class="detail-body">
              <p class="eyebrow">Destination Brief</p>
              <h1>{destination.title}</h1>
              <p class="summary">{destination.summary || "Editorial destination summary will be added soon."}</p>
              <div class="meta-row">
                {destination.region && (
                  <span class="meta-badge"><strong>Region:</strong> {destination.region}</span>
                )}
                {destination.bestSeason && (
                  <span class="meta-badge"><strong>Best season:</strong> {destination.bestSeason}</span>
                )}
              </div>
              {destination.gallery && <ImageGallery images={destination.gallery} title={`${destination.title} gallery`} />}
              {destination.body && <PortableText blocks={destination.body} />}
              {/* DEBUG: check if highlightBoxes and faq exist */}
              <div id="debug-info" style="display:none">
                highlightBoxes: {JSON.stringify(destination.highlightBoxes)}
                faq: {JSON.stringify(destination.faq)}
              </div>
              {destination.highlightBoxes && destination.highlightBoxes.length > 0 && (
                <div class="highlight-boxes">
                  {destination.highlightBoxes.map((box: { _key?: string; boxType?: string; title?: string; body?: string }) => (
                    <aside class={`highlight-box highlight-${box.boxType || 'important'}`}>
                      <div class="highlight-label">{box.boxType || 'important'}</div>
                      {box.title && <strong class="highlight-title">{box.title}</strong>}
                      <p>{box.body}</p>
                    </aside>
                  ))}
                </div>
              )}
              {destination.faq && destination.faq.length > 0 && (
                <div class="faq-section">
                  <h2 class="faq-heading">Frequently Asked Questions</h2>
                  <div class="faq-list">
                    {destination.faq.map((item: { question?: string; answer?: string }, i: number) => (
                      <details class="faq-item" name="faq">
                        <summary class="faq-question">
                          <span class="faq-number">{String(i + 1).padStart(2, '0')}</span>
                          {item.question}
                        </summary>
                        <div class="faq-answer">
                          {(item.answer || '').split('\n').map((line: string, idx: number) => (
                            <p class={line.match(/^\d+\./) ? 'list-item' : ''}>{line}</p>
                          ))}
                        </div>
                      </details>
                    ))}
                  </div>
                </div>
              )}
              <a href="/destinations/" class="back-link">&larr; Back to all destinations</a>
            </div>
          </article>
        ) : (
          <article class="card detail">
            <h1>Destination not found</h1>
            <p>The destination brief you requested is not available yet.</p>
            <a href="/destinations/" class="back-link">&larr; Back to all destinations</a>
          </article>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .detail {
    padding: 0;
    overflow: hidden;
  }

  /* Anchor links: compensate for sticky header */
  .detail-body :global(h2),
  .detail-body :global(h3) {
    scroll-margin-top: 5rem;
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-image-placeholder {
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    background:
      radial-gradient(circle at top right, rgba(15, 107, 154, 0.24), transparent 40%),
      linear-gradient(135deg, #dfeaf4 0%, #edf4fa 100%);
  }

  .hero-image-placeholder span {
    color: var(--primary-strong);
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.1;
    max-width: 16ch;
  }

  .detail-body {
    padding: 1.5rem;
    max-width: 780px;
  }

  .eyebrow {
    margin: 0;
    color: var(--primary);
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  h1 {
    margin: 0.45rem 0 0;
  }

  .summary {
    color: var(--muted);
    margin: 0.7rem 0 0;
    font-size: 1.02rem;
    line-height: 1.65;
    text-align: justify;
    text-justify: inter-word;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .meta-badge {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.35rem 0.7rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .meta-badge strong {
    color: var(--text);
  }

  .back-link {
    display: inline-block;
    margin-top: 1.5rem;
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
  }

  .back-link:hover {
    color: var(--primary-strong);
  }

  @media (max-width: 760px) {
    .hero-image {
      max-height: 260px;
    }
  }

  /* Highlight Boxes */
  .highlight-boxes {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .highlight-box {
    border-radius: 10px;
    padding: 1.1rem 1.2rem;
    border-left: 4px solid;
  }

  .highlight-important {
    background: rgba(237, 28, 36, 0.06);
    border-color: #ed1c24;
  }

  .highlight-budget {
    background: rgba(16, 124, 16, 0.06);
    border-color: #107c10;
  }

  .highlight-route {
    background: rgba(15, 107, 154, 0.06);
    border-color: #0f6b9a;
  }

  .highlight-tip {
    background: rgba(136, 86, 0, 0.06);
    border-color: #885600;
  }

  .highlight-label {
    text-transform: uppercase;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 0.3rem;
    opacity: 0.7;
  }

  .highlight-title {
    display: block;
    font-size: 0.95rem;
    margin-bottom: 0.4rem;
  }

  .highlight-box p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* FAQ Section */
  .faq-section {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 2px solid var(--border);
  }

  .faq-heading {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--primary-strong);
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .faq-item {
    background: var(--surface-raised);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item[open] {
    border-color: var(--primary);
  }

  .faq-question {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.9rem 1.1rem;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    list-style: none;
    color: var(--text);
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::before {
    content: "+";
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary);
    min-width: 1.2rem;
    line-height: 1;
    margin-top: 0.1rem;
  }

  .faq-item[open] .faq-question::before {
    content: "−";
  }

  .faq-number {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--primary);
    background: rgba(15, 107, 154, 0.1);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    min-width: 1.8rem;
    text-align: center;
  }

  .faq-answer {
    padding: 0 1.1rem 0.9rem 1.1rem;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .faq-answer p {
    margin: 0 0 0.5rem;
  }

  .faq-answer p:last-child {
    margin-bottom: 0;
  }

  .faq-answer .list-item {
    padding-left: 0.5rem;
  }
</style>
