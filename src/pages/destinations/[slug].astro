---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDestinationBySlug } from "../../lib/sanity/content";
import PortableText from "../../components/shared/PortableText.astro";
import { resolveDestinationImage } from "../../lib/contentImages";

const { slug = "" } = Astro.params;
const destination = await getDestinationBySlug(slug);
const destinationImage = resolveDestinationImage(destination);

if (!destination) {
  Astro.response.status = 404;
}
---

<BaseLayout
  title={`${destination?.title || "Destination not found"} | SwissWayExplorer`}
  description={destination?.summary || "Destination brief is not available yet."}
  image={destinationImage?.url}
  imageAlt={destinationImage?.alt}
>
  <section class="section">
    <div class="container">
      {
        destination ? (
          <article class="card detail">
            {destinationImage ? (
              <div class="hero-image">
                <img src={destinationImage.url} alt={destinationImage.alt || destination.title} />
              </div>
            ) : (
              <div class="hero-image hero-image-placeholder" aria-hidden="true">
                <span>{destination.title}</span>
              </div>
            )}
            <div class="detail-body">
              <p class="eyebrow">Destination Brief</p>
              <h1>{destination.title}</h1>
              <p class="summary">{destination.summary || "Editorial destination summary will be added soon."}</p>
              <div class="meta-row">
                {destination.region && (
                  <span class="meta-badge"><strong>Region:</strong> {destination.region}</span>
                )}
                {destination.bestSeason && (
                  <span class="meta-badge"><strong>Best season:</strong> {destination.bestSeason}</span>
                )}
              </div>
              {destination.body && <PortableText blocks={destination.body} />}
              <a href="/destinations/" class="back-link">&larr; Back to all destinations</a>
            </div>
          </article>
        ) : (
          <article class="card detail">
            <h1>Destination not found</h1>
            <p>The destination brief you requested is not available yet.</p>
            <a href="/destinations/" class="back-link">&larr; Back to all destinations</a>
          </article>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .detail {
    padding: 0;
    overflow: hidden;
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-image-placeholder {
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    background:
      radial-gradient(circle at top right, rgba(15, 107, 154, 0.24), transparent 40%),
      linear-gradient(135deg, #dfeaf4 0%, #edf4fa 100%);
  }

  .hero-image-placeholder span {
    color: var(--primary-strong);
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.1;
    max-width: 16ch;
  }

  .detail-body {
    padding: 1.5rem;
    max-width: 780px;
  }

  .eyebrow {
    margin: 0;
    color: var(--primary);
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  h1 {
    margin: 0.45rem 0 0;
  }

  .summary {
    color: var(--muted);
    margin: 0.7rem 0 0;
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .meta-badge {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.35rem 0.7rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .meta-badge strong {
    color: var(--text);
  }

  .back-link {
    display: inline-block;
    margin-top: 1.5rem;
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
  }

  .back-link:hover {
    color: var(--primary-strong);
  }

  @media (max-width: 760px) {
    .hero-image {
      max-height: 260px;
    }
  }
</style>
