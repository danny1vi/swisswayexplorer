---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../config/site";
import { sanityFetch } from "../../lib/sanity/client";
import { DESTINATIONS_QUERY } from "../../lib/sanity/queries";
import type { Destination } from "../../lib/sanity/types";

const seedDestinations: Destination[] = siteConfig.featured.map((item) => ({
  title: item.title,
  slug: item.href.split("/").filter(Boolean).pop() || "",
  summary: item.summary,
  image: item.imageUrl ? { url: item.imageUrl, alt: item.title } : undefined,
}));

const sanityDestinations = await sanityFetch<Destination[]>(DESTINATIONS_QUERY, {}, []);
const destinations = sanityDestinations.length > 0 ? sanityDestinations : seedDestinations;
---

<BaseLayout title="Destinations | SwissWayExplorer" description="Switzerland destination overviews and route-first planning notes.">
  <section class="section">
    <div class="container">
      <h1>Destinations</h1>
      <p class="intro">
        Start with the destination profile, not with a random map pin. Each brief is designed to help you decide
        base location, trip rhythm, and realistic day-trip range.
      </p>
      {
        destinations.length === 0 ? (
          <article class="card empty">
            <p>Destination briefs are being prepared. Please check back shortly.</p>
          </article>
        ) : (
          <div class="grid">
            {destinations.map((item) => (
              <article class="card item">
                {item.image ? (
                  <div class="card-image">
                    <img src={item.image.url} alt={item.image.alt || item.title} loading="lazy" />
                  </div>
                ) : (
                  <div class="card-image card-image-placeholder"></div>
                )}
                <div class="item-body">
                  <h2>{item.title}</h2>
                  <p>{item.summary || "Editorial destination overview is coming soon."}</p>
                  <a href={`/destinations/${item.slug}`}>Read destination brief</a>
                </div>
              </article>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    margin: 0;
  }

  .intro {
    margin: 0.65rem 0 1rem;
    color: var(--muted);
    max-width: 72ch;
  }

  .empty,
  .item {
    padding: 0;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .item:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(12, 39, 58, 0.08);
  }

  .empty {
    padding: 1.2rem;
  }

  .empty p {
    margin: 0;
    color: var(--muted);
  }

  .card-image {
    width: 100%;
    height: 140px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-image-placeholder {
    background: linear-gradient(135deg, var(--border) 0%, #e8f0f8 100%);
  }

  .item-body {
    padding: 1.2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .item h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .item p {
    color: var(--muted);
    margin: 0.55rem 0 0;
    min-height: 3.5em;
  }

  .item a {
    display: inline-block;
    margin-top: 0.8rem;
    color: var(--primary);
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 960px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
