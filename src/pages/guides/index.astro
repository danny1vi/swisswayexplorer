---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getGuides } from "../../lib/sanity/content";
import { resolveGuideImage } from "../../lib/contentImages";

const guides = (await getGuides()).map((item) => ({
  ...item,
  image: resolveGuideImage(item),
}));
---

<BaseLayout title="Guides | SwissWayExplorer" description="Practical planning guides for Swiss routes, transport, and timing.">
  <section class="section">
    <div class="container">
      <h1>Guides</h1>
      <p class="intro">
        These guides are written for decision-making, not inspiration scrolling. Use them to lock your route logic,
        ticket strategy, and seasonal expectations before booking.
      </p>
      {
        guides.length === 0 ? (
          <article class="card empty">
            <p>Guides are being prepared. Please check back shortly.</p>
          </article>
        ) : (
          <div class="grid">
            {guides.map((item) => (
              <article class="card item">
                {item.image && (
                  <div class="card-image">
                    <img src={item.image.url} alt={item.image.alt || item.title} loading="lazy" />
                  </div>
                )}
                <div class="item-body">
                <h2>{item.title}</h2>
                {item.category && <p class="meta" data-category={item.category}>{item.category.replace("-", " ")}</p>}
                <p>{item.summary || "Editorial guide summary is coming soon."}</p>
                <a href={`/guides/${item.slug}/`}>Read guide</a>
                </div>
              </article>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    margin: 0;
  }

  .intro {
    margin: 0.65rem 0 1rem;
    color: var(--muted);
    max-width: 72ch;
  }

  .empty,
  .item {
    padding: 0;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .item:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(12, 39, 58, 0.08);
  }

  .empty p {
    margin: 0;
    color: var(--muted);
  }

  .empty {
    padding: 1.2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .card-image {
    width: 100%;
    height: 180px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .item-body {
    padding: 1.2rem;
  }

  .item h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .meta {
    margin: 0.4rem 0 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    display: inline-block;
    color: #fff;
  }

  .meta[data-category="transport"] { background: var(--accent-blue); }
  .meta[data-category="budget"] { background: var(--accent-green); }
  .meta[data-category="itinerary"] { background: var(--accent-amber); }
  .meta[data-category="seasonal"] { background: var(--accent-purple); }

  .item p {
    color: var(--muted);
    margin: 0.55rem 0 0;
  }

  .item a {
    display: inline-block;
    margin-top: 0.8rem;
    color: var(--primary);
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .card-image {
      height: 160px;
    }
  }
</style>
