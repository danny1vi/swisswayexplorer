---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getGuideBySlug } from "../../lib/sanity/content";
import PortableText from "../../components/shared/PortableText.astro";
import ImageGallery from "../../components/shared/ImageGallery.astro";
import { resolveGuideImage } from "../../lib/contentImages";
import GuideDetailSidebar from "../../components/sections/GuideDetailSidebar.astro";

const { slug = "" } = Astro.params;
const guide = await getGuideBySlug(slug);
const guideImage = resolveGuideImage(guide);
const useReadableTypography = slug === "how-to-structure-a-7-day-switzerland-trip";

// Extract headings from body for table of contents
function extractHeadings(body: unknown): Array<{ text: string; depth: number; slug: string }> {
  if (!Array.isArray(body)) return [];
  const headings: Array<{ text: string; depth: number; slug: string }> = [];
  for (const block of body) {
    if (block?._type === "block" && (block.style === "h2" || block.style === "h3")) {
      const text = block.children?.map((c: { text?: string }) => c.text || "").join("") || "";
      const slug = text
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, "")
        .replace(/\s+/g, "-")
        .replace(/-+/g, "-");
      headings.push({ text, depth: block.style === "h2" ? 2 : 3, slug });
    }
  }
  return headings;
}

const headings = extractHeadings(guide?.body);

if (!guide) {
  Astro.response.status = 404;
}
---

<BaseLayout
  title={`${guide?.title || "Guide not found"} | SwissWayExplorer`}
  description={guide?.summary || "Guide brief is not available yet."}
  image={guideImage?.url}
  imageAlt={guideImage?.alt}
>
  <section class="section">
    <div class="container">
      <div class="page-layout">
        <!-- Main article content -->
        <div class="main-content">
          {
            guide ? (
              <article class:list={["card", "detail", useReadableTypography && "detail-readable"]}>
                {guideImage ? (
                  <div class="hero-image">
                    <img src={guideImage.url} alt={guideImage.alt || guide.title} />
                  </div>
                ) : (
                  <div class="hero-image hero-image-placeholder" aria-hidden="true">
                    <span>{guide.title}</span>
                  </div>
                )}
                <div class="detail-body">
                  {guide.category && (
                    <span class="badge" data-category={guide.category}>
                      {guide.category.replace("-", " ")}
                    </span>
                  )}
                  <h1>{guide.title}</h1>
                  <p class="summary">{guide.summary || "Editorial guide summary will be added soon."}</p>
                  {guide.gallery && <ImageGallery images={guide.gallery} title={`${guide.title} gallery`} />}
                  {guide.body && <PortableText blocks={guide.body} variant={useReadableTypography ? "readable" : "default"} />}
                  {guide.faq && guide.faq.length > 0 && (
                    <div class="faq-section">
                      <h2 class="faq-heading">Frequently Asked Questions</h2>
                      <div class="faq-list">
                        {guide.faq.map((item: { question?: string; answer?: string }, i: number) => (
                          <details class="faq-item" name="faq">
                            <summary class="faq-question">
                              <span class="faq-number">{String(i + 1).padStart(2, '0')}</span>
                              {item.question}
                            </summary>
                            <div class="faq-answer">
                              {(item.answer || '').split('\n').map((line: string, idx: number) => (
                                <p class={line.match(/^\d+\./) ? 'list-item' : ''}>{line}</p>
                              ))}
                            </div>
                          </details>
                        ))}
                      </div>
                    </div>
                  )}
                  <a href="/guides/" class="back-link">&larr; Back to all guides</a>
                </div>
              </article>
            ) : (
              <article class="card detail">
                <h1>Guide not found</h1>
                <p>The guide you requested is not available yet.</p>
                <a href="/guides/" class="back-link">&larr; Back to all guides</a>
              </article>
            )
          }
        </div>

        <!-- Sidebar -->
        {
          guide && (
            <GuideDetailSidebar
              currentSlug={guide.slug}
              currentTitle={guide.title}
              currentCategory={guide.category}
              headings={headings}
            />
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .detail {
    padding: 0;
    overflow: hidden;
  }

  .page-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-image-placeholder {
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    background:
      radial-gradient(circle at top right, rgba(26, 143, 205, 0.24), transparent 40%),
      linear-gradient(135deg, #e3eef8 0%, #f0f6fb 100%);
  }

  .hero-image-placeholder span {
    color: var(--primary-strong);
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.1;
    max-width: 18ch;
  }

  .detail-body {
    padding: 1.5rem;
  }

  .badge {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    padding: 0.25rem 0.65rem;
    border-radius: 6px;
    color: #fff;
    display: inline-block;
  }

  .badge[data-category="transport"] {
    background: var(--accent-blue);
  }
  .badge[data-category="budget"] {
    background: var(--accent-green);
  }
  .badge[data-category="itinerary"] {
    background: var(--accent-amber);
  }
  .badge[data-category="seasonal"] {
    background: var(--accent-purple);
  }

  h1 {
    margin: 0.65rem 0 0;
  }

  .summary {
    color: var(--muted);
    margin: 0.7rem 0 0;
    font-size: 1.02rem;
    line-height: 1.65;
    text-align: justify;
    text-justify: inter-word;
  }

  .detail-readable .detail-body {
    padding: 1.8rem 1.75rem 1.9rem;
  }

  .detail-readable h1 {
    font-family: var(--font-reading);
    font-size: clamp(2.1rem, 3.2vw, 2.9rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.2;
    max-width: 15ch;
  }

  .detail-readable .summary {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.78;
    max-width: 62ch;
    color: #415045;
  }

  .back-link {
    display: inline-block;
    margin-top: 1.5rem;
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
  }

  .back-link:hover {
    color: var(--primary-strong);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .page-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero-image {
      max-height: 260px;
    }
  }

  /* FAQ Section */
  .faq-section {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 2px solid var(--border);
  }

  .faq-heading {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--primary-strong);
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .faq-item {
    background: var(--surface-raised);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item[open] {
    border-color: var(--primary-soft);
  }

  .faq-question {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.1rem;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.97rem;
    color: var(--primary-strong);
    list-style: none;
    transition: background 0.15s;
  }

  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::marker { display: none; }

  .faq-question:hover {
    background: var(--surface-hover);
  }

  .faq-number {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--primary);
    background: var(--primary-soft);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .faq-item[open] .faq-number {
    background: var(--primary);
    color: #fff;
  }

  .faq-answer {
    padding: 0.2rem 1.1rem 1rem calc(1.1rem + 0.75rem + 2.2ch);
    font-size: 0.94rem;
    line-height: 1.7;
    color: var(--text);
  }

  .faq-answer p { margin: 0 0 0.5rem; }
  .faq-answer p:last-child { margin-bottom: 0; }
  .faq-answer ol, .faq-answer ul { margin: 0.4rem 0; padding-left: 1.2rem; }
  .faq-answer li { margin-bottom: 0.25rem; }
  .faq-answer .list-item { margin: 0 0 0.35rem; }
</style>
