---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getGuideBySlug, getGuidePaths } from "../../lib/sanity/content";
import type { Guide } from "../../lib/sanity/types";
import PortableText from "../../components/shared/PortableText.astro";
import { resolveGuideImage } from "../../lib/contentImages";

export async function getStaticPaths() {
  const guides = await getGuidePaths();
  return guides.map((item) => ({
    params: { slug: item.slug },
    props: { seedItem: item },
  }));
}

const { slug = "" } = Astro.params;
const { seedItem } = Astro.props as { seedItem?: Guide };
const guide = await getGuideBySlug(slug, seedItem);
const guideImage = resolveGuideImage(guide);

if (!guide) {
  Astro.response.status = 404;
}
---

<BaseLayout
  title={`${guide?.title || "Guide not found"} | SwissWayExplorer`}
  description={guide?.summary || "Guide brief is not available yet."}
  image={guideImage?.url}
  imageAlt={guideImage?.alt}
>
  <section class="section">
    <div class="container">
      {
        guide ? (
          <article class="card detail">
            {guideImage ? (
              <div class="hero-image">
                <img src={guideImage.url} alt={guideImage.alt || guide.title} />
              </div>
            ) : (
              <div class="hero-image hero-image-placeholder" aria-hidden="true">
                <span>{guide.title}</span>
              </div>
            )}
            <div class="detail-body">
              {guide.category && <span class="badge" data-category={guide.category}>{guide.category.replace("-", " ")}</span>}
              <h1>{guide.title}</h1>
              <p class="summary">{guide.summary || "Editorial guide summary will be added soon."}</p>
              {guide.body && <PortableText blocks={guide.body} />}
              <a href="/guides/" class="back-link">&larr; Back to all guides</a>
            </div>
          </article>
        ) : (
          <article class="card detail">
            <h1>Guide not found</h1>
            <p>The guide you requested is not available yet.</p>
            <a href="/guides/" class="back-link">&larr; Back to all guides</a>
          </article>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .detail {
    padding: 0;
    overflow: hidden;
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-image-placeholder {
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    background:
      radial-gradient(circle at top right, rgba(26, 143, 205, 0.24), transparent 40%),
      linear-gradient(135deg, #e3eef8 0%, #f0f6fb 100%);
  }

  .hero-image-placeholder span {
    color: var(--primary-strong);
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.1;
    max-width: 18ch;
  }

  .detail-body {
    padding: 1.5rem;
    max-width: 780px;
  }

  .badge {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    padding: 0.25rem 0.65rem;
    border-radius: 6px;
    color: #fff;
    display: inline-block;
  }

  .badge[data-category="transport"] { background: var(--accent-blue); }
  .badge[data-category="budget"] { background: var(--accent-green); }
  .badge[data-category="itinerary"] { background: var(--accent-amber); }
  .badge[data-category="seasonal"] { background: var(--accent-purple); }

  h1 {
    margin: 0.65rem 0 0;
  }

  .summary {
    color: var(--muted);
    margin: 0.7rem 0 0;
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .back-link {
    display: inline-block;
    margin-top: 1.5rem;
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
  }

  .back-link:hover {
    color: var(--primary-strong);
  }

  @media (max-width: 760px) {
    .hero-image {
      max-height: 260px;
    }
  }
</style>
