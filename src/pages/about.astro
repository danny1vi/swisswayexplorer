---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
---

<BaseLayout title="About | SwissWayExplorer" description="About SwissWayExplorer and our trip-planning approach.">
  <section class="section">
    <div class="container">
      <article class="card page-card">
        <h1>About {siteConfig.name}</h1>
        <p>
          SwissWayExplorer is an editorial travel project focused on one outcome: helping you make better
          Switzerland trip decisions with less noise.
        </p>
        <p>
          Our content is built around planning fundamentals: base selection, transfer logic, day-trip range,
          and seasonal constraints. We prioritize clarity over volume.
        </p>
        <p>
          If a recommendation appears here, it is meant to be practical in real itineraries, not just visually
          appealing on a map.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .page-card {
    padding: 1.5rem;
  }

  h1 {
    margin: 0 0 0.7rem;
  }

  p {
    color: var(--muted);
    margin: 0.7rem 0 0;
    max-width: 72ch;
  }
</style>
